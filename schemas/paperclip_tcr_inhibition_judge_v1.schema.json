{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "paperclip_tcr_inhibition_judge_v1",
  "title": "Paperclip TCR-inhibition judge output (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tf",
    "query",
    "papers_retrieved",
    "papers_relevant",
    "paper_assessments",
    "overall_evidence_tier",
    "key_paperclip_result_ids",
    "tier_rationale",
    "confidence"
  ],
  "properties": {
    "tf": { "type": "string", "minLength": 1 },
    "query": { "type": "string", "minLength": 1 },
    "papers_retrieved": { "type": "integer", "minimum": 0 },
    "papers_relevant": { "type": "integer", "minimum": 0 },
    "paper_assessments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "paperclip_result_id",
          "retrieval_rank",
          "relevant",
          "study_type",
          "experimental_system",
          "evidence_directness",
          "phenotype",
          "direction",
          "supporting_excerpt",
          "rationale"
        ],
        "properties": {
          "paperclip_result_id": { "type": "string" },
          "retrieval_rank": { "type": "integer", "minimum": 0 },
          "relevant": { "type": "boolean" },
          "study_type": {
            "type": "string",
            "enum": [
              "primary experimental",
              "computational or observational",
              "review",
              "other"
            ]
          },
          "experimental_system": { "type": "string" },
          "evidence_directness": {
            "type": "string",
            "enum": [
              "direct causal or perturbational",
              "indirect mechanistic",
              "associative",
              "generic T cell biology",
              "irrelevant"
            ]
          },
          "phenotype": { "type": "string" },
          "direction": {
            "type": "string",
            "enum": [
              "promotes inhibition",
              "opposes inhibition",
              "context dependent",
              "unclear"
            ]
          },
          "supporting_excerpt": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "overall_evidence_tier": {
      "type": "string",
      "enum": ["strong", "moderate", "weak", "none"]
    },
    "key_paperclip_result_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tier_rationale": { "type": "string" },
    "confidence": {
      "type": "string",
      "enum": ["high", "moderate", "low"]
    }
  }
}
