# ---- Python ----
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
*.egg-info/

# ---- OS / editor ----
.DS_Store
.cursor/
.idea/
.vscode/

# ---- Large / restricted data (never commit) ----
# Raw single-cell matrices, checkpoints, embeddings, large intermediates.
*.h5ad
*.ckpt
*.pt
*.npz
*.npy
data/raw/
data/derived/*.h5ad
results/**/embeddings/

# ---- BTLA source data (access-restricted; publication permission pending) ----
# Do NOT commit BTLA transcriptomic/multi-omic source or restricted derived files.
data/btla_source/
**/btla_source*

# ---- logs / scratch ----
logs/
*.log
tmp/

# ---- regenerated / BTLA-derived outputs (untracked until data clearance) ----
# The notebooks regenerate these locally; they expose BTLA-derived results, so they are
# not committed. Provenance (results/model_registry/*_model_registry.csv, *_audit.csv) IS tracked.
results/tables/
results/figures/
results/publication_data/
results/publication_assets/
results/model_registry/benchmark_summary.json
# locally-executed copies kept for review, not committed:
notebooks/executed/

# paperclip scratch search dumps
results/paperclip/_raw_search*.txt

# paperclip v2 raw responses (may contain copyrighted abstracts/snippets/full text)
# Commit the SHA256 manifest (paperclip_raw_manifest.csv) instead of the raw payloads.
results/paperclip/v2_tcr_inhibition/raw/

# multiomics audit: restricted full tables (effect sizes, phosphosite residues, per-target
# direction). Commit only the redacted status tables + provenance hashes alongside them.
**/local_restricted/
results/multiomics/**/local_restricted/
