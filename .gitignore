*.h5ad
*.ckpt
*.pt
*.npz
*.npy
data/raw/
data/derived/*.h5ad
results/**/embeddings/

# ---- BTLA source data (access-restricted; publication permission pending) ----
# Do NOT commit BTLA transcriptomic/multi-omic source or restricted derived files.
data/btla_source/
**/btla_source*

# ---- logs / scratch ----
logs/
*.log
tmp/
